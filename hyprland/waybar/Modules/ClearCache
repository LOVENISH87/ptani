# 5. Remove orphan packages with Yay
printf "\e[1;38;2;0;255;64mв”Џв”Ѓ  в”ів”ів”Џв”“в”Џв”“в”ів”“  в”ів”“в”Џв”“в”Џв”“в”Џв”“  в”Џв”“в”Џв”“в”Џв”“в”“в”Џв”Џв”“  в”Ѓв”“
в”ѓ   в”ѓв”ѓв”—в”“в”Ј в”Јв”«в”Ѓв”Ѓв”Јв”«в”Ј в”ѓв”ѓв”ѓв”ѓ  в”ѓ в”Јв”«в”ѓ в”Јв”«в”Ј    в”ѓ
в”—в”Ѓ  в”—в”›в”—в”›в”—в”›в”›в”—  в”›в”—в”—в”›в”Јв”›в”—в”›  в”—в”›в”›в”—в”—в”›в”›в”—в”—в”›  в”Ѓв”›\e[0m\n"

yay_orphans=$(yay -Qdtq || true)

if [[ -n "$yay_orphans" ]]; then
  printf "\e[38;2;235;250;250m[ ORPHAN PACKAGES: %s ]\e[0m\n" "$yay_orphans"
