orphans=$(pacman -Qdtq || true)

if [[ -n "$orphans" ]]; then
  printf "\e[38;2;235;250;250m[ ORPHAN PACKAGES: %s ]\e[0m\n" "$orphans"
  printf "\e[1;38;2;0;255;64m[ REMOVE ORPHANS? <y/N> ] \e[0m"
  read -r confirm
  echo
  if [[ "$confirm" == [yY] ]]; then
    sudo pacman -Rns -- $orphans
  else
    :
  fi
else
  printf "\e[38;2;235;250;250m[ NO PACMAN-ORPHANS FOUND ]\e[0m\n"
fi

# 3. Clean Flatpak cache and remove unused runtimes
printf "\e[1;38;2;0;255;64mв”Џв”Ѓ  в”Џв”“в”“ в”Џв”“в”Џв”ів”“в”Џв”“в”Џв”“в”“в”Џв”“  в”Џв”“в”Џв”“в”Џв”“в”“в”Џв”Џв”“  в”Ѓв”“
